# 寻龙诀 复盘引擎 — 环境变量样例
# 复制为 .env 并填入真实值。所有变量均可选;未配置时走默认/降级逻辑。

# ---- 数据源适配器 ----
# 数据源提供者:a-stock-data(默认,基于 mootdx+akshare)| thsdk(同花顺,需 THS_* 凭据)| global(全球市场,占位)
DATA_PROVIDER=a-stock-data
# 本地财务 Parquet 根目录(优先读取;未设置时回退 ./data 或 vendor/tickflow-stock-panel/data)
# DATA_DIR=./data

# ---- 复盘数据库 ----
# SQLite 路径,默认 <repo>/data/recap.db
# Docker Compose 固定使用 /shared/recap.db，并将根目录 ./data 挂载到 /shared。
# 本地运行默认使用 ./data/recap.db，也可显式覆盖：
# RECAP_DB_PATH=./data/recap.db

# ---- UZI AI 审计网关(OpenAI 兼容)----
# 填入 AI_API_KEY 后,引擎优先使用本仓库 env,不再依赖 vendored 面板的密钥存储。
# 留空则回退到 vendored 面板 secrets_store;两者皆空则降级为本地规则模拟器。
AI_PROVIDER=openai_compat
# 示例:替换为你的兼容网关地址(不要使用占位值)
# AI_BASE_URL=https://api.example.com/v1
AI_BASE_URL=
AI_API_KEY=
# 模型名(替换为网关支持的真实型号)
# AI_MODEL=gpt-4o-mini
AI_MODEL=
# AI_USER_AGENT=

# ---- 同花顺 thsdk 适配器(仅 DATA_PROVIDER=thsdk 时需要)----
THS_USERNAME=
THS_PASSWORD=
THS_MAC=
