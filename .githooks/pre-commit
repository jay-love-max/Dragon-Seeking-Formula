#!/bin/sh
# Pre-commit hook — 快速代码质量预检
#
# 安装方式：git config core.hooksPath .githooks

echo "🔍 运行 pre-commit 检查..."

# 检查是否有暂存的 Python 文件
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$')

if [ -z "$STAGED_PY" ]; then
    echo "✅ 无 Python 文件变更，跳过检查"
    exit 0
fi

# Ruff 检查
if command -v ruff >/dev/null 2>&1; then
    echo "🔧 运行 ruff check..."
    if ! python3 -m ruff check $STAGED_PY 2>/dev/null; then
        echo "❌ ruff 检查失败，请修复后再提交"
        exit 1
    fi
    echo "✅ ruff 检查通过"
else
    echo "⚠️  ruff 未安装，跳过风格检查"
fi

# 快速语法检查
echo "🔧 运行 Python 语法检查..."
SYNTAX_OK=true
for f in $STAGED_PY; do
    if ! python3 -c "import py_compile; py_compile.compile('$f', doraise=True)" 2>/dev/null; then
        echo "❌ $f 语法错误"
        SYNTAX_OK=false
    fi
done

if [ "$SYNTAX_OK" = false ]; then
    exit 1
fi
echo "✅ 语法检查通过"

exit 0
